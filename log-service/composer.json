{
    "name": "log-service/log-service",
    "description": "Microservice for collecting, processing, and indexing logs via RabbitMQ",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.2",
        "ext-amqp": "*",
        "symfony/framework-bundle": "^7.0",
        "symfony/messenger": "^7.0",
        "symfony/amqp-messenger": "^7.0",
        "symfony/uid": "^7.0",
        "symfony/dotenv": "^7.0",
        "symfony/runtime": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "symfony/browser-kit": "^7.0",
        "symfony/http-client": "^7.0",
        "symfony/phpunit-bridge": "^7.0"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": {
            "*": "dist"
        },
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true,
            "symfony/flex": true,
            "symfony/runtime": true
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "auto-scripts": {},
        "post-install-cmd": ["@auto-scripts"],
        "post-update-cmd": ["@auto-scripts"]
    }
}
